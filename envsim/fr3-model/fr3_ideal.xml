<mujoco model="fr3 ideal torque model">
  <!-- The kinematic and inertial parameters follow the FR3 model used by the original project. -->
  <compiler angle="radian"/>
  <option timestep="0.001" integrator="implicitfast" gravity="0 0 -9.81"/>

  <!-- Default classes keep the included model compact and make every actuator a direct torque input. -->
  <default>
    <default class="fr3">
      <joint damping="0" frictionloss="0" armature="0.195"/>
      <geom type="capsule" size="0.035" rgba="0.88 0.88 0.88 1" contype="0" conaffinity="0"/>
      <site size="0.006" rgba="1 0 0 1"/>
    </default>
  </default>

  <worldbody>
    <!-- The base frame is identical to the MuJoCo world frame. -->
    <body name="base" childclass="fr3">
      <geom type="cylinder" size="0.09 0.08" pos="0 0 0.08" rgba="0.2 0.2 0.2 1"/>
      <body name="fr3_link0">
        <body name="fr3_link1" pos="0 0 0.333">
          <inertial pos="4.128e-07 -0.0181251 -0.0386036" quat="0.998098 -0.0605364 0.00380499 0.0110109" mass="2.92747" diaginertia="0.0239286 0.0227246 0.00610634"/>
          <joint name="fr3_joint1" axis="0 0 1" range="-2.7437 2.7437" limited="true" actuatorfrcrange="-87 87"/>
          <geom fromto="0 0 0 0 0 -0.25"/>

          <body name="fr3_link2" quat="1 -1 0 0">
            <inertial pos="0.00318289 -0.0743222 0.00881461" quat="0.502599 0.584437 -0.465998 0.434366" mass="2.93554" diaginertia="0.0629567 0.0411924 0.0246371"/>
            <joint name="fr3_joint2" axis="0 0 1" range="-1.7837 1.7837" limited="true" actuatorfrcrange="-87 87"/>
            <geom fromto="0 0 0 0 -0.26 0"/>

            <body name="fr3_link3" pos="0 -0.316 0" quat="1 1 0 0">
              <inertial pos="0.0407016 -0.00482006 -0.0289731" quat="0.921025 -0.244161 0.155272 0.260745" mass="2.2449" diaginertia="0.0267409 0.0189869 0.0171587"/>
              <joint name="fr3_joint3" axis="0 0 1" range="-2.9007 2.9007" limited="true" actuatorfrcrange="-87 87"/>
              <geom fromto="0 0 0 0.08 0 0"/>

              <body name="fr3_link4" pos="0.0825 0 0" quat="1 1 0 0">
                <inertial pos="-0.0459101 0.0630493 -0.00851879" quat="0.438018 0.803311 0.00937812 0.403414" mass="2.6156" diaginertia="0.05139 0.0372717 0.0160047"/>
                <joint name="fr3_joint4" axis="0 0 1" range="-3.0421 -0.1518" limited="true" actuatorfrcrange="-87 87"/>
                <geom fromto="0 0 0 -0.08 0.32 0"/>

                <body name="fr3_link5" pos="-0.0825 0.384 0" quat="1 -1 0 0">
                  <inertial pos="-0.00160396 0.0292536 -0.0972966" quat="0.919031 0.125604 0.0751531 -0.366003" mass="2.32712" diaginertia="0.0579335 0.0449144 0.0130634"/>
                  <joint name="fr3_joint5" axis="0 0 1" range="-2.8065 2.8065" limited="true" actuatorfrcrange="-12 12" armature="0.074"/>
                  <geom fromto="0 0 0 0 0 -0.22"/>

                  <body name="fr3_link6" quat="1 1 0 0">
                    <inertial pos="0.0597131 -0.0410295 -0.0101693" quat="0.621301 0.552665 0.510011 0.220081" mass="1.81704" diaginertia="0.0175039 0.0161123 0.00193529"/>
                    <joint name="fr3_joint6" axis="0 0 1" range="0.5445 4.5169" limited="true" actuatorfrcrange="-12 12" armature="0.074"/>
                    <geom fromto="0 0 0 0.088 0 0"/>

                    <body name="fr3_link7" pos="0.088 0 0" quat="1 1 0 0">
                      <inertial pos="0.00452258 0.00862619 -0.0161633" quat="0.727579 0.0978688 -0.24906 0.63168" mass="0.627143" diaginertia="0.000223836 0.000223642 5.64132e-07"/>
                      <joint name="fr3_joint7" axis="0 0 1" range="-3.0159 3.0159" limited="true" actuatorfrcrange="-12 12" armature="0.074"/>
                      <geom fromto="0 0 0 0 0 0.107" size="0.028" rgba="0.2 0.2 0.2 1"/>
                      <!-- This point is the physical flange reference used by the ROS controller. -->
                      <site name="attachment_site" pos="0 0 0.107"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- Motor controls are direct generalized joint torques. -->
  <actuator>
    <motor name="fr3_joint1_motor" joint="fr3_joint1" ctrllimited="true" ctrlrange="-87 87"/>
    <motor name="fr3_joint2_motor" joint="fr3_joint2" ctrllimited="true" ctrlrange="-87 87"/>
    <motor name="fr3_joint3_motor" joint="fr3_joint3" ctrllimited="true" ctrlrange="-87 87"/>
    <motor name="fr3_joint4_motor" joint="fr3_joint4" ctrllimited="true" ctrlrange="-87 87"/>
    <motor name="fr3_joint5_motor" joint="fr3_joint5" ctrllimited="true" ctrlrange="-12 12"/>
    <motor name="fr3_joint6_motor" joint="fr3_joint6" ctrllimited="true" ctrlrange="-12 12"/>
    <motor name="fr3_joint7_motor" joint="fr3_joint7" ctrllimited="true" ctrlrange="-12 12"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0 0 0 -1.57079 0 1.57079 -0.7853" ctrl="0 0 0 0 0 0 0"/>
  </keyframe>
</mujoco>
